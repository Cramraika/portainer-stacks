# immich stack — NON-SECRET variable reference.
#
# At deploy time the real values render via Infisical into immich.env (symlinked
# as .env / stack.env in the Portainer compose dir). This file documents the
# variable surface only — never commit real secrets here.

# --- Storage paths (host paths on vagary-core-1) ---
# Original photos/videos — rclone union mount (external storage)
UPLOAD_LOCATION=/path/to/rclone-union/immich
# Fast local storage for thumbs / encoded-video / cache / backups
LOCAL_STORAGE=/path/to/local-fast/immich
# Postgres data directory
DB_DATA_LOCATION=/path/to/local-fast/immich-db

# --- Database credentials (SECRET — rendered by Infisical, do not commit) ---
DB_PASSWORD=
DB_USERNAME=cadmin
DB_DATABASE_NAME=immich
